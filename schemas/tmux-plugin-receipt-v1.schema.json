{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MatthewssSmith1/dotfiles/blob/main/schemas/tmux-plugin-receipt-v1.schema.json",
  "title": "Dotfiles tmux plugin receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "lock_sha256", "plugins"],
  "properties": {
    "schema_version": {"const": 1},
    "lock_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/plugin"}
    }
  },
  "$defs": {
    "plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "repository", "commit", "tree", "directory"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "repository": {
          "type": "string",
          "pattern": "^https://github\\.com/[A-Za-z0-9._-]+/[A-Za-z0-9._-]+$"
        },
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "tree": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "directory": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$",
          "not": {"enum": [".", ".."]}
        }
      }
    }
  }
}
