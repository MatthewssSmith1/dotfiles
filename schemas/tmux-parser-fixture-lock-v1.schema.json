{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MatthewssSmith1/dotfiles/blob/main/schemas/tmux-parser-fixture-lock-v1.schema.json",
  "title": "Dotfiles tmux parser fixture lock v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "managed_root", "extractor", "fixtures"],
  "properties": {
    "$schema": {"const": "../schemas/tmux-parser-fixture-lock-v1.schema.json"},
    "schema_version": {"const": 1},
    "managed_root": {"const": "tmux-parser-fixtures-v1"},
    "extractor": {"const": ["dpkg-deb", "--extract"]},
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/fixture"},
      "uniqueItems": true
    }
  },
  "$defs": {
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "package", "executable"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "package": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "architecture", "version", "url", "archive", "size", "sha256"],
          "properties": {
            "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9+.-]*$"},
            "architecture": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
            "version": {"type": "string", "minLength": 1},
            "url": {"type": "string", "pattern": "^https://\\S+$"},
            "archive": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]*\\.deb$"},
            "size": {"type": "integer", "minimum": 1},
            "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        },
        "executable": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "mode", "size", "sha256", "version_output"],
          "properties": {
            "path": {"type": "string", "pattern": "^[A-Za-z0-9._+-]+(?:/[A-Za-z0-9._+-]+)+$"},
            "mode": {"const": "0755"},
            "size": {"type": "integer", "minimum": 1},
            "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "version_output": {"type": "string", "pattern": "^tmux \\S+$"}
          }
        }
      }
    }
  }
}
