{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dotfiles.local/schemas/deployment-state-v1.schema.json",
  "$comment": "Documentation only: the authoritative validator is the inline jq expression in validate_state_file (lib/engine.sh). Nothing executes this file; keep it aligned manually.",
  "title": "Dotfiles deployment area state v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile",
    "area",
    "checkout_root",
    "target_root",
    "packages",
    "targets",
    "managed_directories",
    "attachments",
    "backups"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "profile": { "enum": ["omarchy", "generic", "wsl"] },
    "area": { "enum": ["git", "bash", "tmux", "nvim", "zsh"] },
    "checkout_root": { "type": "string", "pattern": "^/" },
    "target_root": { "type": "string", "pattern": "^/" },
    "packages": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9-]+$" }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "source", "resolved_source"],
        "properties": {
          "path": { "$ref": "#/$defs/relativePath" },
          "source": { "type": "string", "minLength": 1 },
          "resolved_source": { "type": "string", "pattern": "^/" }
        }
      }
    },
    "managed_directories": {
      "type": "array",
      "items": { "$ref": "#/$defs/relativePath" }
    },
    "attachments": {
      "type": "array",
      "description": "Attachment IDs and paths are each unique. Area-defined IDs encode the engine origin (created, existing-empty, existing-final-newline, or existing-no-final-newline) needed for exact removal.",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "content_hash"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
          "path": { "$ref": "#/$defs/relativePath" },
          "content_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "backups": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/relativePath" }
    },
    "restored_lock_sha256": {
      "description": "Neovim-only identity written after a complete verified plugin restore.",
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "allOf": [
    {
      "if": { "required": ["restored_lock_sha256"] },
      "then": { "properties": { "area": { "const": "nvim" } } }
    }
  ],
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$)).+$"
    }
  }
}
