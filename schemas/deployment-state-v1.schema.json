{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dotfiles.local/schemas/deployment-state-v1.schema.json",
  "title": "Dotfiles deployment area state v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile",
    "area",
    "checkout_root",
    "target_root",
    "packages",
    "targets",
    "managed_directories",
    "attachments",
    "backups"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "profile": { "enum": ["omarchy", "generic", "wsl"] },
    "area": { "enum": ["git", "bash", "tmux", "nvim", "zsh"] },
    "checkout_root": { "type": "string", "pattern": "^/" },
    "target_root": { "type": "string", "pattern": "^/" },
    "packages": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+/[a-z0-9-]+$" }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "source", "resolved_source"],
        "properties": {
          "path": { "$ref": "#/$defs/relativePath" },
          "source": { "type": "string", "minLength": 1 },
          "resolved_source": { "type": "string", "pattern": "^/" }
        }
      }
    },
    "managed_directories": {
      "type": "array",
      "items": { "$ref": "#/$defs/relativePath" }
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "content_hash"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "path": { "$ref": "#/$defs/relativePath" },
          "content_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "backups": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$)).+$"
    }
  }
}
