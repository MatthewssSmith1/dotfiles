{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MatthewssSmith1/dotfiles/blob/main/schemas/source-manifest-v1.schema.json",
  "title": "Dotfiles upstream source manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "snapshot_root",
    "sources"
  ],
  "properties": {
    "$schema": {
      "const": "../schemas/source-manifest-v1.schema.json"
    },
    "schema_version": {
      "const": 1
    },
    "snapshot_root": {
      "const": "packages/upstream"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    }
  },
  "$defs": {
    "gitMode": {
      "type": "string",
      "enum": [
        "100644",
        "100755"
      ]
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!\\.{1,2}(?:/|$))[^/\\u0000-\\u001f\\u007f]+(?:/(?!\\.{1,2}(?:/|$))[^/\\u0000-\\u001f\\u007f]+)*$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "repository",
        "release",
        "commit",
        "source",
        "snapshot",
        "destination",
        "transform"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "repository": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "release": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "blob",
            "mode"
          ],
          "properties": {
            "path": {
              "$ref": "#/$defs/relativePath"
            },
            "blob": {
              "type": "string",
              "pattern": "^[0-9a-f]{40}$"
            },
            "mode": {
              "$ref": "#/$defs/gitMode"
            }
          }
        },
        "snapshot": {
          "$ref": "#/$defs/relativePath"
        },
        "destination": {
          "oneOf": [
            {
              "$ref": "#/$defs/homeDestination"
            },
            {
              "$ref": "#/$defs/referenceDestination"
            }
          ]
        },
        "transform": {
          "oneOf": [
            {
              "const": "none"
            },
            {
              "$ref": "#/$defs/appendTransform"
            },
            {
              "$ref": "#/$defs/overwriteTransform"
            }
          ]
        }
      }
    },
    "homeDestination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "path",
        "mode"
      ],
      "properties": {
        "root": {
          "const": "home"
        },
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "mode": {
          "$ref": "#/$defs/gitMode"
        }
      }
    },
    "referenceDestination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root"
      ],
      "properties": {
        "root": {
          "const": "reference"
        }
      }
    },
    "appendTransform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "appended",
        "output_blob"
      ],
      "properties": {
        "type": {
          "const": "append"
        },
        "appended": {
          "type": "string",
          "minLength": 1
        },
        "output_blob": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        }
      }
    },
    "overwriteTransform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "replaces"
      ],
      "properties": {
        "type": {
          "const": "overwrite"
        },
        "replaces": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "repository",
            "commit",
            "path",
            "blob",
            "mode"
          ],
          "properties": {
            "repository": {
              "type": "string",
              "format": "uri",
              "pattern": "^https://"
            },
            "commit": {
              "type": "string",
              "pattern": "^[0-9a-f]{40}$"
            },
            "path": {
              "$ref": "#/$defs/relativePath"
            },
            "blob": {
              "type": "string",
              "pattern": "^[0-9a-f]{40}$"
            },
            "mode": {
              "$ref": "#/$defs/gitMode"
            }
          }
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "release",
        "snapshot",
        "destination",
        "sha256",
        "provenance"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "release": {
          "type": "string",
          "minLength": 1
        },
        "snapshot": {
          "$ref": "#/$defs/relativePath"
        },
        "destination": {
          "$ref": "#/$defs/homeDestination"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifact",
            "artifact_sha256",
            "build_date",
            "extracted",
            "trust",
            "record"
          ],
          "properties": {
            "artifact": {
              "type": "string",
              "minLength": 1
            },
            "artifact_sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "build_date": {
              "type": "string",
              "minLength": 1
            },
            "extracted": {
              "type": "string",
              "minLength": 1
            },
            "trust": {
              "type": "string",
              "minLength": 1
            },
            "record": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
