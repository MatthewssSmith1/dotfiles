# Navigation
alias ..="cd .."
alias ...="cd ../.."
alias c='clear'
alias ls='ls --color'

# Editors
alias v='nvim'
alias dot='zed ~/dotfiles'
alias skills='zed ~/.agents/skills'

# Agents
alias oc='clear && opencode'
alias cc='clear && claude'

# Toolchain
alias vr='vp run'
alias npm='pnpm'

# Git
alias gac='git add . && git commit -m'

# Mise
alias mr='mise run'
alias dev='mr dev'
alias build='mr build'
alias d='mr dev'
alias b='mr build'
alias l='mr lint'
alias f='mr fmt'
alias t='mr test'

# Serve Static Files
alias serve='npx live-server .'

# WSL Cleanup
alias dezone="find . -type f -name '*Zone.Identifier' -delete"
